DATABASE_URL=postgresql://user:password@localhost:5432/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Vercel Blob Storage — requerido para que las imágenes carguen correctamente
# Obtenerlo en: https://vercel.com/dashboard > tu proyecto > Storage > Blob > .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxx

# Resend (email de confirmación al crear un lead)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=noreply@tudominio.com
